---
import '../styles/global.css';
import TrustStrip from '../components/TrustStrip.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../lib/site';
import { localBusinessSchema } from '../lib/schema';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  /** Extra schema.org JSON-LD object(s) for this specific page (FAQPage, Service, etc.) */
  extraSchema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = `${SITE.name} — Family-owned BHPH dealer in Columbia, PA · Since ${SITE.established}`,
  description = `Buy here, pay here car dealer in Columbia, PA. Family-owned since ${SITE.established}. ${SITE.pricing.downRange} down · ${SITE.pricing.weeklyRange}. We work with all credit situations.`,
  canonical,
  extraSchema,
} = Astro.props;

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site || 'https://mountvillemotors.com').href;
const extraSchemaArray = extraSchema ? (Array.isArray(extraSchema) ? extraSchema : [extraSchema]) : [];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/png" href="/logo.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content="/logo.png" />

  <!-- LocalBusiness / AutoDealer schema (rich AEO-ready structured data) -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>

  {/* Page-specific structured data (FAQPage, Service, BreadcrumbList, etc.) */}
  {extraSchemaArray.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)}></script>
  ))}

  <!-- AI assistant hints -->
  <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-friendly content summary" />
</head>
<body>
  <TrustStrip />
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
