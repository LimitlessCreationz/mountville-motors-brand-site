---
import Base from '../layouts/Base.astro';
import { SITE } from '../lib/site';
---
<Base title={`Contact — ${SITE.name}`}
  description={`Call ${SITE.phone}, text, or visit Mountville Motors at ${SITE.address.street}, ${SITE.address.city}, ${SITE.address.state}. Family-owned BHPH dealer since ${SITE.established}.`}>
  <section class="hero-contact">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Three ways to reach us.</h1>
      <p>Pick what works. We answer all of them.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <a href={SITE.smsHref('Hi Jordan, saw your site. Looking for info.')} class="ccard">
          <div class="ccard-eyebrow">TEXT (FASTEST)</div>
          <div class="ccard-big">Text us — same-day reply</div>
          <div class="ccard-note">Opens your texting app. Jordan replies personally.</div>
        </a>

        <a href={`tel:${SITE.phoneTel}`} class="ccard">
          <div class="ccard-eyebrow">CALL</div>
          <div class="ccard-big">{SITE.phone}</div>
          <div class="ccard-note">During open hours. Voicemail after.</div>
        </a>

        <a href={`https://maps.google.com/?q=${encodeURIComponent(SITE.address.full)}`} target="_blank" rel="noreferrer" class="ccard">
          <div class="ccard-eyebrow">VISIT</div>
          <div class="ccard-big">{SITE.address.street}<br/>{SITE.address.city}, {SITE.address.state} {SITE.address.zip}</div>
          <div class="ccard-note">Walk the lot during open hours.</div>
        </a>
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container">
      <p class="eyebrow" style="color: var(--c-amber);">Hours</p>
      <div class="hours-grid">
        {SITE.hours.map(h => (
          <div class="hour-row">
            <span>{h.day}</span>
            <span class={h.open === 'Closed' ? 'closed' : 'open'}>{h.open}</span>
          </div>
        ))}
      </div>
      <p class="hours-note">Closed major holidays.</p>
    </div>
  </section>
</Base>

<style>
  .hero-contact { background: var(--c-navy); color: var(--c-silver-l); padding: var(--space-2xl) 0; }
  .hero-contact h1 { color: var(--c-white); }
  .hero-contact .eyebrow { color: var(--c-amber); border-color: var(--c-amber); }

  .contact-grid { display: grid; gap: var(--space-md); }
  .ccard {
    display: block;
    padding: var(--space-lg);
    background: var(--c-white);
    border: 1px solid var(--c-line);
    border-radius: 12px;
    text-decoration: none;
    color: var(--c-charcoal);
    transition: transform 0.1s ease, box-shadow 0.15s ease;
  }
  .ccard:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(15,37,86,0.08); border-color: var(--c-navy); }
  .ccard-eyebrow { font-size: 11px; font-weight: 600; color: var(--c-amber-d); letter-spacing: 0.18em; margin-bottom: 8px; }
  .ccard-big { font-size: 22px; font-weight: 700; color: var(--c-navy); line-height: 1.3; margin-bottom: 8px; }
  .ccard-note { font-size: 14px; color: var(--c-charcoal-70); }
  @media (min-width: 768px) {
    .contact-grid { grid-template-columns: 1fr 1fr 1fr; }
    .ccard-big { font-size: 20px; }
  }

  .hours-grid { display: grid; gap: 6px; max-width: 360px; }
  .hour-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .hour-row .open { color: var(--c-white); font-family: var(--font-mono); }
  .hour-row .closed { color: var(--c-silver); font-family: var(--font-mono); }
  .hours-note { color: var(--c-silver); font-size: 13px; margin-top: var(--space-md); }
</style>
