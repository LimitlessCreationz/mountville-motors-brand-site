---
import { SITE } from '../lib/site';
const { reviews, established } = SITE;
---
<div class="trust-strip">
  Family-owned since {established} · <span class="star">★ {reviews.rating}</span> · {reviews.count} {reviews.source} reviews
</div>

<style>
  .trust-strip {
    background: var(--c-off-white);
    color: var(--c-charcoal-70);
    border-bottom: 1px solid var(--c-line);
    padding: 6px 12px;
    text-align: center;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1.3;
  }
  .star { color: var(--c-amber-d); }
  @media (min-width: 768px) {
    .trust-strip { font-size: 12px; padding: 8px 16px; }
  }
</style>
