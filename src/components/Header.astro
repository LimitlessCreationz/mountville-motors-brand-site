---
import { SITE } from '../lib/site';
const { name, phone, phoneTel } = SITE;
const navItems = [
  { label: 'Inventory',   href: '/inventory' },
  { label: 'Financing',   href: '/financing' },
  { label: 'About',       href: '/about' },
  { label: 'Appointments',href: '/appointments' },
  { label: 'Payments',    href: '/payments' },
  { label: 'Contact',     href: '/contact' },
];
---
<header class="hdr">
  <div class="hdr-inner">
    <a href="/" class="brand">
      <img src="/logo.png" alt={name} class="logo" width="38" height="38" />
      <div class="brand-text">
        <div class="brand-name">MOUNTVILLE</div>
        <div class="brand-sub">MOTOR SALES · PA</div>
      </div>
    </a>
    <a href={`tel:${phoneTel}`} class="call-btn" aria-label={`Call ${phone}`}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      Call
    </a>
    <button class="menu-btn" id="mm-menu-btn" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="nav" id="mm-nav">
    {navItems.map(item => (
      <a href={item.href} class="nav-link">{item.label}</a>
    ))}
    <a href={SITE.applyUrl} class="nav-link nav-cta">Get pre-qualified →</a>
  </nav>
</header>

<style>
  .hdr {
    background: var(--c-white);
    border-bottom: 1px solid var(--c-line);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .hdr-inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 12px var(--space-md);
    max-width: var(--container-desktop);
    margin: 0 auto;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--c-charcoal);
    flex: 1;
    min-width: 0;
  }
  .logo {
    background: var(--c-navy);
    border-radius: 8px;
    padding: 4px;
    width: 38px;
    height: 38px;
  }
  .brand-text { line-height: 1.1; }
  .brand-name {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .brand-sub {
    font-size: 10px;
    color: var(--c-silver);
    letter-spacing: 0.16em;
  }
  .call-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--c-navy);
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    padding: 10px 14px;
    border-radius: 8px;
    border: 1px solid var(--c-line);
    min-height: var(--tap-min);
  }
  .menu-btn {
    background: transparent;
    border: 1px solid var(--c-line);
    width: var(--tap-min);
    height: var(--tap-min);
    border-radius: 8px;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
  }
  .menu-btn span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--c-charcoal);
    border-radius: 1px;
  }
  .nav {
    display: none;
    flex-direction: column;
    background: var(--c-white);
    border-top: 1px solid var(--c-line);
    padding: var(--space-md);
    gap: 4px;
  }
  .nav.open { display: flex; }
  .nav-link {
    color: var(--c-charcoal);
    text-decoration: none;
    padding: 14px;
    font-weight: 600;
    border-radius: 8px;
    min-height: var(--tap-min);
    display: flex;
    align-items: center;
  }
  .nav-link:hover { background: var(--c-off-white); }
  .nav-cta {
    background: var(--c-amber);
    color: var(--c-navy-deep) !important;
    margin-top: 8px;
    justify-content: center;
  }
  @media (min-width: 768px) {
    .menu-btn { display: none; }
    .nav {
      display: flex;
      flex-direction: row;
      align-items: center;
      border-top: none;
      padding: 0 var(--space-md) 0 0;
      max-width: var(--container-desktop);
      margin: 0 auto;
      flex-wrap: wrap;
      gap: 4px;
      padding-bottom: 8px;
    }
    .nav-link { padding: 8px 14px; font-size: 14px; }
    .nav-cta { margin-top: 0; margin-left: auto; }
  }
</style>

<script>
  const btn = document.getElementById('mm-menu-btn');
  const nav = document.getElementById('mm-nav');
  btn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(!!open));
  });
</script>
